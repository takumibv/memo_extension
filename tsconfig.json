{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "types": ["vitest/globals", "chrome"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "exclude": ["old", "packages", "chrome-extension", "pages", "node_modules", ".output", "dist"]
}
